%% Global review diagram.
%% Clarifies whole-practitioner inputs, review decisions, and programming outputs.
flowchart LR
  classDef input fill:#eef2ff,stroke:#4354a3,color:#111
  classDef review fill:#fff8dd,stroke:#8a6d00,color:#111
  classDef decision fill:#eef7ee,stroke:#2f6f4e,color:#111
  classDef block fill:#ffeceb,stroke:#9b2c2c,color:#111

  subgraph Inputs["Global Review Inputs"]
    direction TB
    BranchLevels["BranchLevelState by branch:<br/>unopened, training, test-ready, passed once, stabilizing, owned, maintenance, decayed"]:::input
    MaintenanceStatus["Maintenance status and overdue checks"]:::input
    RecentFailures["Last three failures and classifications"]:::input
    Artifacts["Evidence artifacts from tests, transfer, stabilization, and maintenance"]:::input
    Bottlenecks["Current bottleneck branch or capacity"]:::input
    VolumeIntensity["Volume and intensity history"]:::input
    RecoveryDeload["Recovery and deload history"]:::input
  end

  Review["Global review<br/>whole-practitioner check, not isolated drill review"]:::review
  PassCheck{"Review pass requirements met?<br/>no prerequisite decay<br/>no overdue maintenance<br/>bottleneck has programmed response<br/>current transfer or stabilization artifact<br/>no participation-only advancement"}:::review

  subgraph Decisions["Review Decisions"]
    direction TB
    Continue["Continue current progression"]:::decision
    Emphasize["Emphasize bottleneck branch"]:::decision
    Restore["Restore decayed branch"]:::decision
    OpenAdvanced["Open advanced branch"]:::decision
    PauseTests["Pause tests for deload"]:::decision
    AttemptTI["Attempt TI transfer"]:::decision
  end

  subgraph Outputs["Programming Outputs"]
    direction TB
    PractitionerState["Updated PractitionerState"]:::decision
    WeeklyEmphasis["Next weekly emphasis and session mix"]:::decision
    MaintenancePlan["Maintenance and restoration plan"]:::decision
    AdvancementCaps["Advancement caps or unlocks"]:::decision
    FailReview["Review fails:<br/>advanced classification and dependent advancement blocked"]:::block
  end

  BranchLevels --> Review
  MaintenanceStatus --> Review
  RecentFailures --> Review
  Artifacts --> Review
  Bottlenecks --> Review
  VolumeIntensity --> Review
  RecoveryDeload --> Review

  Review --> PassCheck
  PassCheck -->|Yes| Continue
  PassCheck -->|Yes| Emphasize
  PassCheck -->|Yes| OpenAdvanced
  PassCheck -->|Yes| AttemptTI
  PassCheck -->|No| Restore
  PassCheck -->|No| PauseTests
  PassCheck -->|No| FailReview

  Continue --> PractitionerState
  Emphasize --> WeeklyEmphasis
  Restore --> MaintenancePlan
  OpenAdvanced --> AdvancementCaps
  PauseTests --> WeeklyEmphasis
  AttemptTI --> AdvancementCaps
  FailReview --> AdvancementCaps
